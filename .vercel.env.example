# Required Environment Variables for Vercel Deployment
# Set these in your Vercel Project Dashboard:
#   https://vercel.com/YOUR_TEAM/icad/settings/environment-variables

# --- Laravel Core ---
APP_NAME=ICAD
APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:YOUR_GENERATED_APP_KEY_HERE
APP_URL=https://icad.vercel.app

# Generate with: php artisan key:generate --show
# Or run locally: echo "APP_KEY=$(php artisan key:generate --show)" >> .env

# --- Database ---
# SQLite does NOT work on Vercel (read-only filesystem).
# Use PostgreSQL (Supabase/Neon) or MySQL (PlanetScale):
DB_CONNECTION=pgsql
DB_HOST=your-db-host.com
DB_PORT=5432
DB_DATABASE=icad
DB_USERNAME=icad_user
DB_PASSWORD=your_secure_password

# --- Session ---
# Use database or redis (NOT file) on serverless:
SESSION_DRIVER=database
SESSION_LIFETIME=120

# --- Cache ---
CACHE_STORE=database
# or use redis:
# CACHE_STORE=redis

# --- Queue ---
QUEUE_CONNECTION=sync

# --- Mail ---
MAIL_MAILER=log
# Configure your mail provider:
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.sendgrid.net
# MAIL_PORT=587
# MAIL_USERNAME=apikey
# MAIL_PASSWORD=your_sendgrid_key

# --- Storage ---
FILESYSTEM_DISK=s3
# or local (uses /tmp, WILL be lost on cold starts):
# FILESYSTEM_DISK=local

# AWS S3 for file uploads (optional):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=me-central-1
# AWS_BUCKET=icad-uploads

# --- Vite ---
VITE_APP_NAME=ICAD
